@using Microsoft.Extensions.Options
@using StocksApp.Infrastructure.CustomOptions
@model StockTradeViewModel;
@inject IOptions<TradingOptions> options;

<!-- Breadcrumb -->
<div class="mb">
    <span class="text-grey">Stocks</span>
    <i class="bi bi-chevron-right text-grey" style="font-size:0.7em;"></i>
    <span>@Model.StockName</span>
</div>

<div class="box trading-panel flex trading-panel-flex">

    <!-- Stock price panel -->
    <div id="stock-price-panel">
        <div class="stock-title">
            @Model.StockName (@Model.StockSymbol)
        </div>
        <div class="mt">
            <span class="text-grey">$</span>
            <span class="stock-price" id="stockPrice">@Model.Price</span>
        </div>
    </div>

    <!-- New order panel -->
    <div id="new-order-panel">
        <div class="text-grey mb">New Order</div>

        <div class="form-field flex">
            <div>
                <label class="form-label" for="quantity">Quantity:</label>
            </div>
            <div>
                <input asp-for="Quantity" type="number" class="form-input" id="quantity" />
                <span asp-validation-for="Quantity"></span>
            </div>
        </div>

        <div class="button-panel">

            <!-- Sell Form -->
            <form id="sellOrderForm" method="post" asp-controller="Trade" asp-action="SellOrder" style="display:inline;">
                <input type="hidden" asp-for="StockSymbol" />
                <input type="hidden" asp-for="StockName" />
                <input type="hidden" asp-for="Price" />
                <input type="hidden" asp-for="Quantity" id="sellQuantity" />
                <button type="submit" class="trading-button button button-red-back">
                    <i class="bi bi-arrow-down-circle"></i> Sell
                </button>
            </form>

            <!-- Buy Form -->
            <form id="buyOrderForm" method="post" asp-controller="Trade" asp-action="BuyOrder" style="display:inline;">
                <input type="hidden" asp-for="StockSymbol" />
                <input type="hidden" asp-for="StockName" />
                <input type="hidden" asp-for="Price" />
                <input type="hidden" asp-for="Quantity" id="buyQuantity" />
                <button type="submit" class="trading-button button button-green-back">
                    <i class="bi bi-arrow-up-circle"></i> Buy
                </button>
            </form>

        </div>
    </div>

</div>

<!-- JavaScript: WebSocket + مزامنة الكمية مع الفورمين -->
<input type="hidden" id="StockSymbol" value="@Model.StockSymbol" />
<script>
    const quantityInput = document.getElementById('quantity');
    const sellQuantity = document.getElementById('sellQuantity');
    const buyQuantity = document.getElementById('buyQuantity');

    quantityInput.addEventListener('input', function () {
        sellQuantity.value = quantityInput.value;
        buyQuantity.value = quantityInput.value;
    });

    const stockSymbol = document.getElementById('StockSymbol').value;
    const token = "@(options.Value.SecretToken)";
    const socket = new WebSocket(`wss://ws.finnhub.io?token=${token}`);

    socket.addEventListener('open', function (event) {
        socket.send(JSON.stringify({ 'type': 'subscribe', 'symbol': stockSymbol }));
    });

    socket.addEventListener('message', function (event) {
        const response = JSON.parse(event.data);
        if (response.type === 'trade' && response.data && response.data.length > 0) {
            const latestPrice = response.data[0].p;
            document.getElementById('stockPrice').innerText = latestPrice.toFixed(2);
        }
    });

    window.addEventListener('beforeunload', function () {
        socket.send(JSON.stringify({ 'type': 'unsubscribe', 'symbol': stockSymbol }));
        socket.close();
    });
</script>