@model SelectedStockViewModel

<div class="box" style="max-width:400px;">

    <img src="@Model.Logo" alt="@Model.Name" style="width:80px; height:80px; border-radius:8px; margin-bottom:10px;" />

    <div class="stock-title" style="font-size:1.6em;">
        @Model.Name (@Model.Symbol)
    </div>

    <div class="mt mb">
        <span style="background-color:#929292; color:#ffffff; padding:4px 10px; border-radius:12px; font-size:0.85em;">
            @Model.Industry
        </span>
    </div>

    <div class="mb">
        <strong>Exchange:</strong>
        <span style="background-color:#3a81bd; color:#ffffff; padding:4px 10px; border-radius:6px; font-size:0.85em;">
            @Model.Exchange
        </span>
    </div>

    <div class="mb">
        <span class="text-grey">$</span>
        <span class="stock-price">@Model.Price.ToString("N2")</span>
    </div>

    <div class="button-panel">
        <a asp-controller="Trade" asp-action="Index" asp-route-stockSymbol="@Model.Symbol"
           class="button button-blue-back">Trade Now</a>
    </div>

</div>